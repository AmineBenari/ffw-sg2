<mujoco model="ffw_sg2 scene">
  <include file="ffw_sg2.xml"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <!-- Physics floor: contact surface at z=0, invisible -->
    <geom name="floor" size="0 0 0.05" type="plane" rgba="0 0 0 0"
          contype="1" conaffinity="1"/>
    <!-- Visual floor: 25 mm below physics surface — wheel mesh vertices dip
         ~20 mm below z=0 during rotation, so 25 mm clears all z-fighting -->
    <geom name="floor_visual" size="0 0 0.05" type="plane" material="groundplane"
          pos="0 0 -0.025" contype="0" conaffinity="0" group="2"/>
  </worldbody>
</mujoco>
